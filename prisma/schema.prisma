// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============== ENUMS ==============

enum Region {
  br
  eune
  euw
  jp
  kr
  lan
  las
  na
  oce
  tr
  ru
  ph
  sg
  th
  tw
  vn

  @@map("region")
}

enum QueueType {
  RANKED_SOLO_5x5
  RANKED_FLEX_SR
  RANKED_FLEX_TT
  RANKED_TFT

  @@map("queue_type")
}

enum Tier {
  IRON
  BRONZE
  SILVER
  GOLD
  PLATINUM
  EMERALD
  DIAMOND
  MASTER
  GRANDMASTER
  CHALLENGER

  @@map("tier")
}

// ============== MODELS ==============

model Summoner {
  puuid String @id @db.Uuid

  gameName      String   @db.VarChar(32)
  tagLine       String   @db.VarChar(8)
  summonerLevel Int      @default(1) @map("summoner_level")
  profileIconId Int      @default(1) @map("profile_icon_id")
  revisionDate  DateTime @map("revision_date") @db.Timestamp(3)
  region        String   @db.VarChar(10)

  lastUpdatedAt DateTime @updatedAt @map("last_updated_at") @db.Timestamp(3)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  matchList SummonerMatchlist[]
  names     SummonerName[]
  matches   MatchPlayer[]

  @@index([region])
  @@index([gameName, tagLine])
  @@index([lastUpdatedAt])
  @@map("summoners")
}

model SummonerName {
  id Int @id @default(autoincrement())

  summonerPuuid String @map("summoner_puuid") @db.Uuid
  gameName      String @db.VarChar(32) @map("game_name")
  previousNick  String? @db.VarChar(32) @map("previous_nick")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(3)

  summoner Summoner @relation(fields: [summonerPuuid], references: [puuid], onDelete: Cascade)

  @@index([summonerPuuid])
  @@index([gameName])
  @@map("summoner_names")
}

model Match {
  matchId String @id @db.VarChar(32) @map("match_id")

  dataVersion String   @db.VarChar(16) @map("data_version")
  metadata    Json?

  gameCreation DateTime @map("game_creation") @db.Timestamp(3)
  gameDuration Int      @map("game_duration")
  gameMode     String   @db.VarChar(32) @map("game_mode")
  gameType     String   @db.VarChar(32) @map("game_type")
  queueId      Int      @map("queue_id")
  mapId        Int      @map("map_id")
  patch        String   @db.VarChar(16)
  season       Int      @default(0)
  region       String   @db.VarChar(10)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  teams   MatchTeam[]
  players MatchPlayer[]

  @@index([gameCreation])
  @@index([queueId])
  @@index([mapId])
  @@index([season])
  @@index([region])
  @@index([gameCreation, season])
  @@index([patch])
  @@map("matches")
}

model MatchTeam {
  id Int @id @default(autoincrement())

  matchId String @map("match_id") @db.VarChar(32)
  teamId  Int    @map("team_id")

  win               Boolean
  towerKills        Int     @map("tower_kills")
  inhibitorKills    Int     @map("inhibitor_kills")
  baronKills        Int     @map("baron_kills")
  dragonKills       Int     @map("dragon_kills")
  riftHeraldKills   Int     @default(0) @map("rift_herald_kills")
  elderDragonKills  Int     @default(0) @map("elder_dragon_kills")
  bans              Int[]   @db.Integer

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  match Match @relation(fields: [matchId], references: [matchId], onDelete: Cascade)

  @@index([matchId])
  @@index([teamId])
  @@unique([matchId, teamId])
  @@map("match_teams")
}

model MatchPlayer {
  id Int @id @default(autoincrement())

  matchId       String @map("match_id") @db.VarChar(32)
  summonerPuuid String @map("summoner_puuid") @db.Uuid
